# ══════════════════════════════════════════════════════════
# Variables de entorno del SIEM — Plantilla sin valores reales
# Copiá este archivo como .env y completá los valores
# ══════════════════════════════════════════════════════════

# URL pública de n8n para webhooks de Telegram.
# Cambiar SOLO esta línea cada vez que reiniciés ngrok.
# Sin ngrok (solo motor ML): usar http://localhost:5678
N8N_WEBHOOK_URL=https://tu-url-ngrok.ngrok-free.dev

# Credenciales PostgreSQL
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=tesis_siem

# Credenciales servidor víctima SSH (pruebas RU-1)
SSH_USER=admin
SSH_PASSWORD=password
